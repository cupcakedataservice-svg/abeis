# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Build output ───────────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/

# ── Logs ────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Package manager artifacts ───────────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# ── Editor / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Vite cache ───────────────────────────────────────────────────────────────────
.vite/
*.local

# ── Misc ──────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
coverage/
.cache/

# ── Uploaded/recorded media if ever saved locally during dev ────────────────────
backend/uploads/
backend/tmp/
*.webm

# ── Python Virtual Environment ────────────────────────────────────────────────
backend/python-worker/venv/
backend/python-worker/.venv/

# ── Python Cache ──────────────────────────────────────────────────────────────
backend/python-worker/__pycache__/
**/__pycache__/

*.pyc
*.pyo
*.pyd

# ── Python Temporary Files ────────────────────────────────────────────────────
backend/python-worker/temp/
backend/python-worker/tmp/

# ── Jupyter (if used later) ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Python Tooling ────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/

# Baseline generated files
backend/baseline/generated/

# Baseline reports and logs
backend/baseline/baseline_generation.log
backend/baseline/filtered_dataset.csv
backend/baseline/baseline_generation_report.txt

# Optional: local datasets
backend/baseline/*.csv
!backend/baseline/sample_dataset.csv