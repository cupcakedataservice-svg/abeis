.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Build output ───────────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/

# ── Logs ────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Package manager artifacts ───────────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

