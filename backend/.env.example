PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/abeis?retryWrites=true&w=majority

# ImageKit
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# CORS
FRONTEND_URL=http://localhost:5173

# Privacy policy version shown in consent records
PRIVACY_POLICY_VERSION=1.0.0

# Admin credentials (MVP — replace with DB-backed auth later)
ADMIN_ID=ADMIN001
ADMIN_PASSWORD=ADMIN@001

# JWT secret for admin sessions (generate a strong random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# Deletion safety: when an admin deletes a user / clears the dataset, the
# backend deletes ImageKit media files first. By default, if ANY ImageKit
# file fails to delete, the corresponding MongoDB records are NOT deleted
# either (to avoid orphaning cloud files with no DB reference). Set this to
# "true" to force MongoDB deletion to proceed anyway even if some ImageKit
# files could not be removed (a warning will still be returned).
DELETE_MONGO_ON_IMAGEKIT_FAILURE=false
